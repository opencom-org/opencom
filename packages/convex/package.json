{
  "name": "@opencom/convex",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "main": "./convex/_generated/api.js",
  "types": "./convex/_generated/api.d.ts",
  "exports": {
    ".": {
      "types": "./convex/_generated/api.d.ts",
      "import": "./convex/_generated/api.js",
      "require": "./runtime/api.cjs"
    },
    "./dataModel": {
      "types": "./convex/_generated/dataModel.d.ts",
      "import": "./runtime/dataModel.js",
      "require": "./runtime/dataModel.cjs"
    }
  },
  "files": [
    "convex/_generated/api.d.ts",
    "convex/_generated/api.js",
    "convex/_generated/dataModel.d.ts",
    "runtime",
    "convex/README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "convex dev",
    "deploy": "convex deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "cleanup:e2e": "tsx scripts/cleanup-e2e-data.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.18",
    "@auth/core": "0.41.1",
    "@convex-dev/auth": "^0.0.90",
    "ai": "^6.0.48",
    "convex": "^1.31.7",
    "convex-test": "^0.0.41",
    "jose": "^6.1.3",
    "oslo": "^1.2.1",
    "resend": "^6.8.0"
  },
  "devDependencies": {
    "dotenv": "^17.2.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.17"
  },
  "opencom": {
    "release": {
      "supportTier": "supported",
      "releaseChannels": [
        "latest",
        "next"
      ],
      "releaseTestCommand": "pnpm --filter @opencom/convex test -- --run tests/discovery.test.ts",
      "notes": "Generated backend contract package consumed by public SDK packages."
    }
  }
}
